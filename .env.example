# Gemini API Key (obtén una gratis en https://aistudio.google.com/app/apikey)
# Necesaria para usar modelos Gemini
GOOGLE_API_KEY=TU_API_KEY_AQUI

# Modelo primario (default: gemini-3.1-flash-lite)
ADK_MODEL=gemini-3.1-flash-lite

# Modelo de fallback (default: ollama_chat/qwen2.5:3b)
# Se activa cuando el modelo primario falla (ej. cuota agotada)
ADK_FALLBACK_MODEL=ollama_chat/qwen2.5:3b
